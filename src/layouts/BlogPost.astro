---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const { title, pubDate, description, tags } = post.data;

const readingTime = 6;

const date = new Date(pubDate);
const formattedDate = date.toLocaleDateString("en-GB", {
  day: "numeric", month: "long", year: "numeric"
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <style>
    :root {
      --navy:    #1B2A41;
      --navy-60: rgba(27,42,65,.6);
      --slate:   #5C6B7A;
      --paper:   #F7F5F0;
      --white:   #FFFFFF;
      --gold:    #B08D57;
      --gold-dk: #8C6B3D;
      --gold-lt: #F0E8D8;
      --line:    #E4E0D8;
      --tag-bg:  #EDEAE3;
      --good:    #2D6A0A;
      --prose-w: 68ch;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--paper);
      color: var(--navy);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 18px;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
    }

    #progress {
      position: fixed; top: 0; left: 0; height: 3px;
      background: var(--gold); width: 0%;
      transition: width .1s linear; z-index: 100;
    }

    .topnav {
      position: sticky; top: 0; z-index: 50;
      background: rgba(247,245,240,.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--line);
      padding: 0 24px;
      display: flex; align-items: center; justify-content: space-between;
      height: 52px;
    }
    .topnav a {
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: 13px; font-weight: 600;
      color: var(--slate); text-decoration: none;
      letter-spacing: .04em; text-transform: uppercase;
      display: flex; align-items: center; gap: 6px;
      transition: color .15s;
    }
    .topnav a:hover { color: var(--navy); }
    .topnav a::before { content: "←"; }
    .topnav .site-name {
      font-family: Georgia, serif; font-size: 15px; font-weight: 400;
      color: var(--navy); letter-spacing: 0; text-transform: none;
    }
    .topnav .site-name::before { display: none; }

    .article-header {
      max-width: 900px; margin: 0 auto;
      padding: 56px 24px 48px;
      border-bottom: 1px solid var(--line);
    }

    .tags-row {
      display: flex; flex-wrap: wrap; gap: 8px;
      margin-bottom: 24px;
    }
    .tag {
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: 11px; font-weight: 700;
      letter-spacing: .1em; text-transform: uppercase;
      color: var(--gold-dk); background: var(--gold-lt);
      padding: 4px 12px; border-radius: 999px;
      border: 1px solid rgba(176,141,87,.25);
    }

    .article-title {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 400; line-height: 1.15;
      letter-spacing: -.01em; color: var(--navy);
      margin-bottom: 20px;
    }

    .article-description {
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: 18px; line-height: 1.6;
      color: var(--slate); max-width: 60ch;
      margin-bottom: 28px;
    }

    .article-meta {
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: 13px; color: var(--slate);
      display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    }
    .article-meta .sep { color: var(--line); }
    .article-meta .read-time {
      display: flex; align-items: center; gap: 5px;
    }
    .article-meta .read-time::before {
      content: "◷"; font-size: 14px; color: var(--gold);
    }

    .article-body {
      max-width: var(--prose-w);
      margin: 0 auto;
      padding: 52px 24px 80px;
    }

    .article-body > :global(p:first-of-type)::first-letter {
      font-family: Georgia, serif;
      font-size: 3.6em; line-height: .8;
      float: left; margin: .06em .1em 0 0;
      color: var(--gold-dk); font-weight: 400;
    }

    .article-body :global(p) { margin-bottom: 1.6em; }

    .article-body :global(h2) {
      font-family: Georgia, serif;
      font-size: 1.45em; font-weight: 400;
      color: var(--navy); letter-spacing: -.01em;
      margin: 2.4em 0 .7em;
      padding-top: 2em;
      border-top: 1px solid var(--line);
      line-height: 1.3;
    }

    .article-body :global(h3) {
      font-family: Georgia, serif;
      font-size: 1.15em; font-weight: 700;
      color: var(--navy); margin: 2em 0 .5em;
      line-height: 1.35;
    }

    .article-body :global(blockquote) {
      margin: 2.4em 0;
      padding: 28px 32px;
      background: var(--white);
      border-left: 3px solid var(--gold);
      border-radius: 0 8px 8px 0;
      box-shadow: 0 2px 12px rgba(27,42,65,.06);
    }
    .article-body :global(blockquote p) {
      font-size: 1.12em; font-style: italic;
      color: var(--navy); margin: 0;
      line-height: 1.65;
    }

    .article-body :global(p:has(strong:only-child)),
    .article-body :global(p > strong:first-child:last-child) {
      background: var(--gold-lt);
      border: 1px solid rgba(176,141,87,.3);
      border-radius: 8px;
      padding: 16px 20px;
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: .95em;
    }

    .article-body :global(strong) { font-weight: 700; color: var(--navy); }
    .article-body :global(em) { font-style: italic; color: var(--slate); }

    .article-body :global(a) {
      color: var(--gold-dk);
      text-decoration: underline;
      text-decoration-color: rgba(140,107,61,.35);
      text-underline-offset: 3px;
      transition: text-decoration-color .15s, color .15s;
    }
    .article-body :global(a:hover) {
      color: var(--navy);
      text-decoration-color: var(--gold);
    }

    .article-body :global(ul),
    .article-body :global(ol) {
      padding-left: 1.5em;
      margin-bottom: 1.6em;
    }
    .article-body :global(li) { margin-bottom: .5em; }
    .article-body :global(ul li::marker) { color: var(--gold); }

    .article-body :global(code) {
      font-family: "SF Mono", "Fira Code", monospace;
      font-size: .85em;
      background: var(--tag-bg);
      padding: 2px 6px; border-radius: 4px;
      color: var(--navy);
    }

    .article-body :global(pre) {
      background: var(--navy);
      color: #e8e6e1;
      padding: 24px; border-radius: 10px;
      overflow-x: auto; margin: 2em 0;
      font-size: .85em; line-height: 1.65;
    }
    .article-body :global(pre code) {
      background: none; padding: 0; color: inherit;
    }

    .article-body :global(hr) {
      border: none;
      border-top: 1px solid var(--line);
      margin: 3em auto;
      width: 48px;
    }

    .article-body :global(p em:only-child) {
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: 13px; color: var(--slate);
      font-style: normal;
      display: block;
      padding-top: 2em;
      border-top: 1px solid var(--line);
      margin-top: 1em;
    }

    .article-footer {
      max-width: var(--prose-w);
      margin: 0 auto;
      padding: 0 24px 80px;
      display: flex; align-items: center;
      justify-content: space-between;
      flex-wrap: wrap; gap: 16px;
      border-top: 1px solid var(--line);
      padding-top: 32px;
    }
    .back-link {
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: 14px; font-weight: 600;
      color: var(--slate); text-decoration: none;
      display: flex; align-items: center; gap: 6px;
      transition: color .15s;
    }
    .back-link:hover { color: var(--navy); }
    .back-link::before { content: "←"; }

    .share-btn {
      font-family: -apple-system, "Segoe UI", sans-serif;
      font-size: 13px; font-weight: 600;
      background: var(--navy); color: var(--white);
      border: none; border-radius: 8px;
      padding: 10px 20px; cursor: pointer;
      transition: background .15s;
    }
    .share-btn:hover { background: #2C3E5A; }
    /* Images dans l'article */
    .article-body :global(img) {
      max-width: 100%;
      width: auto;
      max-height: 350px;
      height: auto;
      border-radius: 8px;
      margin: 2em auto;
      display: block;
      object-fit: cover;
    }
    @media (max-width: 600px) {
      .article-header { padding: 36px 20px 36px; }
      .article-body { padding: 40px 20px 60px; }
      .article-body > :global(p:first-of-type)::first-letter {
        font-size: 2.8em;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #progress { transition: none; }
    }

    @media print {
      #progress, .topnav, .article-footer { display: none; }
      body { font-size: 12pt; }
    }
  </style>
</head>
<body>

  <div id="progress"></div>

  <nav class="topnav">
    <a href="/blog">All posts</a>
    <a href="/" class="site-name">AI &amp; Education</a>
  </nav>

  <header class="article-header">
    {tags && tags.length > 0 && (
      <div class="tags-row">
        {tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}

    <h1 class="article-title">{title}</h1>

    {description && (
      <p class="article-description">{description}</p>
    )}

    <div class="article-meta">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span class="sep">·</span>
      <span class="read-time">{readingTime} min read</span>
    </div>
  </header>

  <article class="article-body">
    <Content />
  </article>

  <footer class="article-footer">
    <a href="/blog" class="back-link">Back to all posts</a>
    <button class="share-btn" onclick="navigator.clipboard.writeText(window.location.href).then(()=>{this.textContent='Link copied!';setTimeout(()=>this.textContent='Copy link',2000)})">
      Copy link
    </button>
  </footer>

  <script is:inline>
    const bar = document.getElementById("progress");
    function updateProgress() {
      const doc = document.documentElement;
      const scrolled = doc.scrollTop || document.body.scrollTop;
      const total = doc.scrollHeight - doc.clientHeight;
      bar.style.width = total > 0 ? (scrolled / total * 100) + "%" : "0%";
    }
    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
  </script>

</body>
</html>
