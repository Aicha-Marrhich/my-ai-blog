---
// School AI Readiness Assessment
---


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>School AI Readiness Assessment</title>
<style>
:root{
  --navy:#1B2A41;--navy-soft:#2C3E5A;--slate:#5C6B7A;
  --paper:#F6F4EF;--paper-deep:#EFEBE2;
  --gold:#B08D57;--gold-light:#F1E6D2;--gold-deep:#8C6B3D;
  --line:#E2DED3;--line-soft:#EDEAE1;
  --good:#3B6D11;--good-bg:#EAF3DF;
  --mid:#9A5B0C;--mid-bg:#FBF0DD;
  --low:#A32D2D;--low-bg:#FAE6E6;
  --white:#FFFFFF;
  --shadow-sm:0 1px 2px rgba(27,42,65,.06);
  --shadow-md:0 4px 16px rgba(27,42,65,.08);
  --shadow-lg:0 12px 32px rgba(27,42,65,.12);
}
*{box-sizing:border-box}
body{
  margin:0;
  background:linear-gradient(180deg,var(--paper) 0%,var(--paper-deep) 100%);
  background-attachment:fixed;
  color:var(--navy);
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;
  line-height:1.6;
  -webkit-font-smoothing:antialiased;
}
.wrap{max-width:760px;margin:0 auto;padding:56px 24px 90px;animation:fadeIn .5s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

header.top{padding-bottom:28px;margin-bottom:36px;position:relative}
header.top::after{content:"";position:absolute;bottom:0;left:0;width:64px;height:3px;background:var(--gold);border-radius:3px}
.eyebrow{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-deep);font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;background:var(--gold)}
h1{font-family:Georgia,"Times New Roman",serif;font-size:34px;font-weight:400;margin:0 0 14px;color:var(--navy);letter-spacing:-.01em}
.subtitle{color:var(--slate);font-size:16px;max-width:58ch}

.progress-track{height:6px;background:var(--line);border-radius:6px;margin:32px 0 40px;overflow:hidden;box-shadow:inset 0 1px 2px rgba(27,42,65,.08)}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--gold-deep),var(--gold));border-radius:6px;width:0%;transition:width .4s cubic-bezier(.4,0,.2,1)}

.dim-label{font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--gold-deep);font-weight:700;margin-bottom:10px;display:flex;align-items:center;gap:6px}

.question-card{
  background:var(--white);border:1px solid var(--line);border-radius:16px;
  padding:36px;margin-bottom:28px;box-shadow:var(--shadow-md);
  transition:box-shadow .2s ease;
}
.question-text{font-family:Georgia,serif;font-size:22px;font-weight:400;margin:0 0 28px;color:var(--navy);line-height:1.45}

.options{display:flex;flex-direction:column;gap:12px}
.option{
  display:flex;align-items:center;gap:14px;
  border:1.5px solid var(--line);border-radius:12px;
  padding:16px 18px;cursor:pointer;font-size:15.5px;
  background:var(--white);
  transition:border-color .15s ease,background .15s ease,transform .12s ease,box-shadow .15s ease;
  position:relative;
}
.option:hover{border-color:var(--gold);background:var(--gold-light);transform:translateX(2px)}
.option:active{transform:scale(.99)}
.option .radio{
  flex:0 0 auto;width:20px;height:20px;border-radius:50%;
  border:2px solid var(--line);position:relative;transition:border-color .15s ease;
}
.option .radio::after{
  content:"";position:absolute;inset:3px;border-radius:50%;
  background:var(--gold);transform:scale(0);transition:transform .15s cubic-bezier(.4,0,.2,1);
}
.option.selected{border-color:var(--gold);background:var(--gold-light);font-weight:600;box-shadow:var(--shadow-sm)}
.option.selected .radio{border-color:var(--gold)}
.option.selected .radio::after{transform:scale(1)}
.option .label-text{flex:1}

.nav-row{display:flex;justify-content:space-between;align-items:center;gap:16px}

button{
  font-family:inherit;font-size:14.5px;padding:14px 30px;border-radius:10px;
  cursor:pointer;border:1.5px solid var(--navy);background:var(--navy);color:var(--white);
  font-weight:600;letter-spacing:.01em;transition:transform .12s ease,box-shadow .15s ease,background .15s ease;
  box-shadow:var(--shadow-sm);
}
button:hover:not(:disabled){background:var(--navy-soft);box-shadow:var(--shadow-md);transform:translateY(-1px)}
button:active:not(:disabled){transform:translateY(0)}
button:disabled{opacity:.32;cursor:not-allowed;box-shadow:none}
button.secondary{background:var(--white);color:var(--navy)}
button.secondary:hover:not(:disabled){background:var(--paper-deep)}
.start-btn{font-size:15.5px;padding:16px 36px;border-radius:12px}

.dims-list{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin:32px 0 36px}
.dim-chip{
  border:1px solid var(--line);border-radius:12px;padding:16px 18px;background:var(--white);
  box-shadow:var(--shadow-sm);transition:transform .15s ease,box-shadow .15s ease;
}
.dim-chip:hover{transform:translateY(-2px);box-shadow:var(--shadow-md)}
.dim-chip .num{font-family:Georgia,serif;font-size:13px;color:var(--gold-deep);font-weight:700}
.dim-chip .name{font-size:14.5px;font-weight:600;margin-top:4px}

.hint{color:var(--slate);font-size:14px;display:flex;align-items:center;gap:8px;margin-bottom:32px}
.hint::before{content:"🔒";font-size:13px}

.score-hero{
  text-align:center;padding:48px 24px;border:1px solid var(--line);background:var(--white);
  border-radius:20px;margin-bottom:36px;box-shadow:var(--shadow-lg);position:relative;overflow:hidden;
}
.score-hero::before{content:"";position:absolute;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--gold-deep),var(--gold))}
.score-big{font-family:Georgia,serif;font-size:68px;color:var(--navy);line-height:1;letter-spacing:-.02em}
.score-band{
  display:inline-block;font-size:14px;letter-spacing:.06em;text-transform:uppercase;font-weight:700;
  margin-top:14px;padding:7px 18px;border-radius:999px;
}

.report-section{margin-top:44px}
.report-section h2{font-family:Georgia,serif;font-size:21px;font-weight:400;border-bottom:1px solid var(--line);padding-bottom:12px;margin-bottom:20px;color:var(--navy)}

.dim-results{display:flex;flex-direction:column;gap:14px;margin:0}
.dim-row{background:var(--white);border:1px solid var(--line);border-radius:14px;padding:20px 22px;box-shadow:var(--shadow-sm);transition:box-shadow .2s ease}
.dim-row:hover{box-shadow:var(--shadow-md)}
.dim-row-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px}
.dim-row-name{font-weight:600;font-size:15px}
.dim-row-score{font-family:Georgia,serif;font-size:18px;color:var(--navy)}
.bar-track{height:9px;background:var(--line);border-radius:5px;overflow:hidden;margin-bottom:12px;box-shadow:inset 0 1px 2px rgba(27,42,65,.08)}
.bar-fill{height:100%;border-radius:5px;transition:width .5s cubic-bezier(.4,0,.2,1)}
.dim-row-rec{font-size:14px;color:var(--slate);line-height:1.55}

.next-steps{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:12px}
.next-steps li{
  font-size:15px;background:var(--white);border:1px solid var(--line);border-radius:12px;
  padding:16px 18px;box-shadow:var(--shadow-sm);
}
.next-steps li strong{color:var(--gold-deep)}

.actions-row{display:flex;gap:14px;margin-top:44px;flex-wrap:wrap}
footer.credit{margin-top:60px;padding-top:22px;border-top:1px solid var(--line);font-size:13px;color:var(--slate);text-align:center}

@media print{.actions-row{display:none}}
@media(max-width:560px){
  .wrap{padding:36px 18px 70px}
  .dims-list{grid-template-columns:1fr}
  .score-big{font-size:48px}
  h1{font-size:27px}
  .question-card{padding:24px 20px}
  .question-text{font-size:19px}
}
</style>
</head>
<body>
<div class="wrap" id="app"></div>
<script>
const D=[{k:"infra",n:"Infrastructure & access",q:[{t:"How would you describe device and internet access for students at your school?",o:[{l:"Inconsistent — many students lack reliable devices or connectivity",s:0},{l:"Basic — shared devices available but limited",s:1},{l:"Good — most students have regular access",s:2},{l:"Excellent — 1:1 devices with reliable connectivity for all",s:3}]},{t:"Does your school currently provide access to any AI tools for staff or students?",o:[{l:"No AI tools are currently provided",s:0},{l:"A few staff use personal AI tools informally",s:1},{l:"Some approved tools are available to certain groups",s:2},{l:"A range of vetted AI tools is available school-wide",s:3}]},{t:"How equipped is your IT infrastructure to support AI tool integration (data security, system compatibility)?",o:[{l:"Not assessed or known to be inadequate",s:0},{l:"Some gaps identified, no plan yet",s:1},{l:"Mostly adequate, minor gaps",s:2},{l:"Fully assessed and AI-ready",s:3}]}]},{k:"staff",n:"Staff AI literacy",q:[{t:"How confident are teachers, on average, in understanding what AI is and how it works?",o:[{l:"Most staff have little to no understanding",s:0},{l:"Basic awareness, but limited practical understanding",s:1},{l:"Good general understanding across most staff",s:2},{l:"Strong, confident understanding school-wide",s:3}]},{t:"Has your school provided any AI-related professional development for staff?",o:[{l:"No training has been offered",s:0},{l:"One-off session or optional resources only",s:1},{l:"Some structured training for interested staff",s:2},{l:"Ongoing, mandatory professional development programme",s:3}]},{t:"How are teachers currently using AI in their own planning or workload?",o:[{l:"Not at all, or actively discouraged",s:0},{l:"A few individuals experiment informally",s:1},{l:"Many staff use it regularly for planning support",s:2},{l:"Embedded as standard practice with clear guidance",s:3}]}]},{k:"policy",n:"Policy & governance",q:[{t:"Does your school have a written AI use policy?",o:[{l:"No policy exists",s:0},{l:"Informal guidance only, nothing written",s:1},{l:"A draft policy exists but isn't finalised",s:2},{l:"A clear, communicated policy is in place",s:3}]},{t:"How does your school currently handle data privacy concerns related to AI tools?",o:[{l:"Not yet considered",s:0},{l:"Aware of the issue, no formal process",s:1},{l:"Some vetting process exists for new tools",s:2},{l:"Robust, documented data governance process",s:3}]},{t:"How clear are your academic integrity guidelines regarding AI use by students?",o:[{l:"No guidance exists",s:0},{l:"Informal expectations, not documented",s:1},{l:"Written guidance exists for some subjects",s:2},{l:"Clear, consistent guidance across the school",s:3}]}]},{k:"curriculum",n:"Curriculum integration",q:[{t:"Is AI literacy currently taught anywhere in your curriculum?",o:[{l:"Not addressed anywhere",s:0},{l:"Touched on briefly in one subject or assembly",s:1},{l:"Integrated into a few subjects",s:2},{l:"Embedded across multiple subjects and year groups",s:3}]},{t:"How are AI tools being used to support teaching and learning in lessons?",o:[{l:"Not used in lessons at all",s:0},{l:"Occasional, individual teacher experimentation",s:1},{l:"Used regularly in several subject areas",s:2},{l:"Thoughtfully integrated as a teaching tool school-wide",s:3}]},{t:"Does your school have a plan to align AI literacy teaching with frameworks such as the OECD AILit Framework?",o:[{l:"Not aware of such frameworks",s:0},{l:"Aware, but no plan to align",s:1},{l:"Beginning to explore alignment",s:2},{l:"Actively aligning curriculum to a recognised framework",s:3}]}]},{k:"student",n:"Student AI literacy",q:[{t:"How would you describe students' current understanding of how AI systems work?",o:[{l:"Very limited understanding",s:0},{l:"Basic awareness from informal use",s:1},{l:"Reasonable understanding for most students",s:2},{l:"Strong, critical understanding across year groups",s:3}]},{t:"Are students taught to critically evaluate AI-generated content?",o:[{l:"Not taught at all",s:0},{l:"Mentioned occasionally, not formally taught",s:1},{l:"Taught in some subjects or year groups",s:2},{l:"Consistently taught as a core skill",s:3}]},{t:"Do students have opportunities to discuss the ethical and societal implications of AI?",o:[{l:"No such opportunities exist",s:0},{l:"Occasional, informal discussion",s:1},{l:"Built into some subjects (e.g. PSHE, citizenship)",s:2},{l:"Regular, structured opportunities across the curriculum",s:3}]}]}];
const B=[{min:0,max:.99,l:"Early stage",c:"var(--low)",bg:"var(--low-bg)",d:"Your school is at the very beginning of its AI journey. This is a completely normal starting point — the goal now is building foundational awareness and a simple first policy."},{min:1,max:1.74,l:"Emerging",c:"var(--mid)",bg:"var(--mid-bg)",d:"Pockets of activity exist but lack coordination. The priority is connecting these efforts under a shared plan."},{min:1.75,max:2.49,l:"Developing",c:"var(--mid)",bg:"var(--mid-bg)",d:"Solid foundations are in place across most areas. Focus now on consistency and embedding practice school-wide."},{min:2.5,max:3,l:"Advanced",c:"var(--good)",bg:"var(--good-bg)",d:"Your school is well-positioned on AI readiness. The focus now is refinement, evaluation, and sharing practice with others."}];
const Q=D.flatMap(d=>d.q.map(q=>({...q,dk:d.k,dn:d.n})));
let S={sc:"intro",c:0,a:new Array(Q.length).fill(null)};
function gB(s){return B.find(b=>s>=b.min&&s<=b.max)||B[0]}
function rF(k,bl){const R={infra:{"Early stage":"Start by mapping current device and connectivity gaps across the school.","Emerging":"Pilot one or two vetted AI tools with a small staff group before wider rollout.","Developing":"Formalise an approved tools list and review data security with IT.","Advanced":"Document your infrastructure approach so it can be shared with other schools."},staff:{"Early stage":"Run a single introductory AI session for all staff this term.","Emerging":"Identify 2-3 AI champions per department to lead informal peer training.","Developing":"Move from optional to structured, ongoing professional development.","Advanced":"Consider mentoring other schools or leading a local training network."},policy:{"Early stage":"Draft a one-page interim AI use policy this month as a starting point.","Emerging":"Finalise and formally communicate a written policy to all stakeholders.","Developing":"Review your policy against the EU AI Act and OECD guidance for gaps.","Advanced":"Publish your policy as a model for other schools in your network."},curriculum:{"Early stage":"Identify one subject area to pilot AI literacy content this term.","Emerging":"Map AI literacy opportunities across at least three subjects.","Developing":"Align your curriculum explicitly with the OECD AILit Framework's four domains.","Advanced":"Document your approach as a case study for wider sector sharing."},student:{"Early stage":"Introduce one classroom discussion on what AI is and how it works.","Emerging":"Build a short cross-curricular unit on critically evaluating AI output.","Developing":"Embed AI ethics discussions consistently across PSHE and relevant subjects.","Advanced":"Create student-led AI literacy initiatives such as peer workshops."}};return R[k][bl]||"Continue building consistent practice in this area."}
function ren(){const A=document.getElementById("app");if(S.sc==="intro")A.innerHTML=rI();else if(S.sc==="quiz")A.innerHTML=rQ();else A.innerHTML=rR()}
function rI(){return`<header class="top"><div class="eyebrow">Free diagnostic tool</div><h1>School AI Readiness Assessment</h1><p class="subtitle">A 15-question diagnostic for school and system leaders to evaluate readiness for AI integration across five dimensions — and get a tailored action plan in under five minutes.</p></header><div class="dims-list">${D.map((d,i)=>`<div class="dim-chip"><div class="num">0${i+1}</div><div class="name">${d.n}</div></div>`).join("")}</div><p class="hint">Takes about 5 minutes. Answers are not stored or sent anywhere — everything runs in your browser.</p><button class="start-btn" onclick="sQ()">Begin assessment →</button>`}
function sQ(){S.sc="quiz";S.c=0;ren()}
function rQ(){const q=Q[S.c];const p=Math.round((S.c/Q.length)*100);const s=S.a[S.c];return`<header class="top"><div class="eyebrow">School AI Readiness Assessment</div><h1 style="font-size:24px;">Question ${S.c+1} of ${Q.length}</h1></header><div class="progress-track"><div class="progress-fill" style="width:${p}%"></div></div><div class="question-card"><div class="dim-label">${q.dn}</div><p class="question-text">${q.t}</p><div class="options">${q.o.map((o,i)=>`<div class="option ${s===i?"selected":""}" onclick="sA(${i})"><span class="radio"></span><span class="label-text">${o.l}</span></div>`).join("")}</div></div><div class="nav-row"><button class="secondary" onclick="pQ()" ${S.c===0?"disabled":""}>← Back</button><button onclick="nQ()" ${s===null?"disabled":""}>${S.c===Q.length-1?"See my results →":"Next →"}</button></div>`}
function sA(i){S.a[S.c]=i;ren()}
function nQ(){if(S.c===Q.length-1){S.sc="results"}else{S.c++}ren()}
function pQ(){if(S.c>0){S.c--;ren()}}
function cR(){const ds=D.map(d=>{const qi=Q.map((q,i)=>({q,i})).filter(x=>x.q.dk===d.k).map(x=>x.i);const t=qi.reduce((s,i)=>{const ai=S.a[i];return s+Q[i].o[ai].s},0);const a=t/qi.length;return{k:d.k,n:d.n,a:a}});const o=ds.reduce((s,d)=>s+d.a,0)/ds.length;return{ds,o}}
function rR(){const cr=cR();const b=gB(cr.o);const so=[...cr.ds].sort((a,b)=>a.a-b.a);const w=so.slice(0,2);return`<header class="top"><div class="eyebrow">Your results</div><h1>AI Readiness Report</h1><p class="subtitle">Based on your answers across five dimensions of school AI readiness.</p></header><div class="score-hero"><div class="score-big">${cr.o.toFixed(1)}<span style="font-size:24px;color:var(--slate);"> / 3.0</span></div><div class="score-band" style="color:${b.c};background:${b.bg}">${b.l}</div><p style="max-width:48ch;margin:16px auto 0;color:var(--slate);font-size:15px;">${b.d}</p></div><div class="report-section"><h2>Readiness by dimension</h2><div class="dim-results">${cr.ds.map(d=>{const b2=gB(d.a);const p=(d.a/3)*100;return`<div class="dim-row"><div class="dim-row-top"><span class="dim-row-name">${d.n}</span><span class="dim-row-score">${d.a.toFixed(1)} / 3.0</span></div><div class="bar-track"><div class="bar-fill" style="width:${p}%;background:${b2.c};"></div></div><div class="dim-row-rec">${b2.l} — ${rF(d.k,b2.l)}</div></div>`}).join("")}</div></div><div class="report-section"><h2>Where to focus first</h2><ul class="next-steps">${w.map(d=>`<li><strong>${d.n}:</strong> ${rF(d.k,gB(d.a).l)}</li>`).join("")}<li><strong>General:</strong> Share this report with your leadership team and revisit the assessment again in 6 months to track progress.</li></ul></div><div class="actions-row"><button onclick="window.print()">Save as PDF</button><button class="secondary" onclick="res()">Retake assessment</button></div><footer class="credit">School AI Readiness Assessment — a free open diagnostic tool. Built to help school leaders move from AI anxiety to AI action.</footer>`}
function res(){S={sc:"intro",c:0,a:new Array(Q.length).fill(null)};ren()}
ren();
</script>
</body>
</html>
