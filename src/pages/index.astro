---
const posts = Object.values(import.meta.glob('./blog/*.md', { eager: true }));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Aicha Marrhich · AI & Education</title>
    <meta name="description" content="Exploring how AI transforms education, work, and lifelong learning. Research briefs and insights by Aicha Marrhich." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg: #faf9f7;
        --surface: #ffffff;
        --surface-elevated: #ffffff;
        --text: #1a1a1a;
        --text-secondary: #525252;
        --text-muted: #737373;
        --accent: #1e3a5f;
        --accent-light: #2d5a87;
        --accent-warm: #b87333;
        --border: #e5e5e5;
        --border-light: #f0f0f0;
      }
      
      * { box-sizing: border-box; margin: 0; padding: 0; }
      
      html { scroll-behavior: smooth; }
      
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }
      
      /* NAVIGATION */
      .site-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        padding: 1.25rem 2rem;
        z-index: 1000;
        background: rgba(250, 249, 247, 0.85);
        backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid var(--border-light);
        transition: all 0.3s ease;
      }
      
      .nav-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .logo {
        font-family: 'Crimson Pro', serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.02em;
      }
      
      .nav-links {
        display: flex;
        gap: 2.5rem;
        align-items: center;
      }
      
      .nav-links a {
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
        position: relative;
      }
      
      .nav-links a::after {
        content: '';
        position: absolute;
        bottom: -4px; left: 0;
        width: 0; height: 1.5px;
        background: var(--accent);
        transition: width 0.3s ease;
      }
      
      .nav-links a:hover {
        color: var(--text);
      }
      
      .nav-links a:hover::after {
        width: 100%;
      }
      
      .nav-cta {
        background: var(--accent);
        color: white;
        padding: 0.6rem 1.25rem;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s;
      }
      
      .nav-cta:hover {
        background: var(--accent-light);
        transform: translateY(-1px);
      }
      
      /* HERO */
      .hero {
        min-height: 90vh;
        display: flex;
        align-items: center;
        padding: 8rem 2rem 4rem;
        max-width: 1200px;
        margin: 0 auto;
      }
      
      .hero-inner {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 4rem;
        align-items: center;
        width: 100%;
      }
      
      .hero-content {
        max-width: 600px;
      }
      
      .hero-label {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent-warm);
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 1.5rem;
      }
      
      .hero-label::before {
        content: '';
        width: 24px; height: 1.5px;
        background: var(--accent-warm);
      }
      
      .hero h1 {
        font-family: 'Crimson Pro', serif;
        font-size: clamp(2.8rem, 5vw, 4.2rem);
        font-weight: 400;
        line-height: 1.15;
        margin-bottom: 1.5rem;
        color: var(--text);
        letter-spacing: -0.02em;
      }
      
      .hero h1 em {
        font-style: italic;
        color: var(--accent);
      }
      
      .hero p {
        font-size: 1.15rem;
        color: var(--text-secondary);
        line-height: 1.8;
        margin-bottom: 2.5rem;
        max-width: 520px;
      }
      
      .hero-actions {
        display: flex;
        gap: 1rem;
        align-items: center;
      }
      
      .btn-primary {
        background: var(--accent);
        color: white;
        padding: 0.9rem 1.8rem;
        border-radius: 10px;
        font-weight: 500;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      
      .btn-primary:hover {
        background: var(--accent-light);
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(30, 58, 95, 0.2);
      }
      
      .btn-secondary {
        color: var(--text-secondary);
        padding: 0.9rem 1.8rem;
        border-radius: 10px;
        font-weight: 500;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s;
        border: 1.5px solid var(--border);
      }
      
      .btn-secondary:hover {
        border-color: var(--accent);
        color: var(--accent);
      }
      
      .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
      }
      
      .hero-orb {
        width: 320px; height: 320px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(30, 58, 95, 0.08), rgba(184, 115, 51, 0.06));
        position: relative;
        animation: orbBreathe 8s ease-in-out infinite;
      }
      
      @keyframes orbBreathe {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
      }
      
      .hero-orb-inner {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 240px; height: 240px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(30, 58, 95, 0.12), rgba(184, 115, 51, 0.08));
        animation: orbBreathe 8s ease-in-out infinite reverse;
      }
      
      .hero-emoji {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        font-size: 4rem;
      }
      
      /* SECTIONS */
      .section {
        padding: 5rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
      }
      
      .section-header {
        margin-bottom: 3rem;
      }
      
      .section-label {
        color: var(--accent-warm);
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
      }
      
      .section h2 {
        font-family: 'Crimson Pro', serif;
        font-size: 2.2rem;
        font-weight: 400;
        margin-bottom: 0.75rem;
      }
      
      .section-desc {
        color: var(--text-secondary);
        font-size: 1.05rem;
        max-width: 600px;
      }
      
      /* BENTO GRID */
      .bento-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
      }
      
      .bento-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.75rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
      }
      
      .bento-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.06);
        border-color: var(--border);
      }
      
      .bento-card.featured {
        grid-column: span 2;
        background: linear-gradient(135deg, var(--accent), var(--accent-light));
        color: white;
        border: none;
      }
      
      .bento-card.featured .bento-tag {
        background: rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.9);
      }
      
      .bento-card.featured .bento-title {
        color: white;
      }
      
      .bento-card.featured .bento-desc {
        color: rgba(255,255,255,0.8);
      }
      
      .bento-card.featured .bento-meta {
        color: rgba(255,255,255,0.6);
      }
      
      .bento-tag {
        display: inline-block;
        background: var(--border-light);
        color: var(--text-muted);
        padding: 0.25rem 0.75rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 500;
        margin-bottom: 1rem;
      }
      
      .bento-title {
        font-family: 'Crimson Pro', serif;
        font-size: 1.3rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: var(--text);
        line-height: 1.3;
      }
      
      .bento-desc {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 1.25rem;
      }
      
      .bento-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.8rem;
        color: var(--text-muted);
      }
      
      .bento-link {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        text-decoration: none;
        z-index: 1;
      }
      
      /* THEMES */
      .themes-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
      
      .theme-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s;
        cursor: pointer;
      }
      
      .theme-card:hover {
        border-color: var(--accent);
        transform: translateY(-2px);
      }
      
      .theme-icon {
        font-size: 2rem;
        margin-bottom: 0.75rem;
      }
      
      .theme-name {
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-secondary);
      }
      
      /* QUIZ SECTION */
      .quiz-section {
        background: linear-gradient(135deg, var(--accent), #0f2440);
        border-radius: 24px;
        padding: 4rem;
        margin: 3rem 2rem;
        max-width: 1160px;
        margin-left: auto;
        margin-right: auto;
        position: relative;
        overflow: hidden;
      }
      
      .quiz-section::before {
        content: '';
        position: absolute;
        top: -100px; right: -100px;
        width: 300px; height: 300px;
        border-radius: 50%;
        background: rgba(255,255,255,0.03);
      }
      
      .quiz-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        position: relative;
        z-index: 1;
      }
      
      .quiz-content h2 {
        font-family: 'Crimson Pro', serif;
        font-size: 2.5rem;
        color: white;
        margin-bottom: 1rem;
        font-weight: 400;
      }
      
      .quiz-content p {
        color: rgba(255,255,255,0.75);
        font-size: 1.1rem;
        line-height: 1.7;
        margin-bottom: 2rem;
      }
      
      .quiz-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: white;
        color: var(--accent);
        padding: 1rem 2rem;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s;
      }
      
      .quiz-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      }
      
      .quiz-visual {
        display: flex;
        justify-content: center;
        align-items: center;
      }
      
      .quiz-preview {
        background: rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 2rem;
        border: 1px solid rgba(255,255,255,0.1);
        width: 100%;
        max-width: 320px;
      }
      
      .quiz-preview-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }
      
      .quiz-preview-item:last-child {
        border-bottom: none;
      }
      
      .quiz-preview-letter {
        width: 32px; height: 32px;
        border-radius: 8px;
        background: rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 0.8rem;
        font-weight: 600;
      }
      
      .quiz-preview-text {
        color: rgba(255,255,255,0.7);
        font-size: 0.85rem;
      }
      
      /* NEWSLETTER */
      .newsletter {
        text-align: center;
        padding: 5rem 2rem;
        max-width: 600px;
        margin: 0 auto;
      }
      
      .newsletter h2 {
        font-family: 'Crimson Pro', serif;
        font-size: 2rem;
        margin-bottom: 1rem;
      }
      
      .newsletter p {
        color: var(--text-secondary);
        margin-bottom: 2rem;
      }
      
      .newsletter-form {
        display: flex;
        gap: 0.75rem;
        max-width: 450px;
        margin: 0 auto;
      }
      
      .newsletter-input {
        flex: 1;
        padding: 0.9rem 1.25rem;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        font-size: 0.95rem;
        font-family: inherit;
        background: var(--surface);
        outline: none;
        transition: border-color 0.3s;
      }
      
      .newsletter-input:focus {
        border-color: var(--accent);
      }
      
      .newsletter-btn {
        background: var(--accent);
        color: white;
        border: none;
        padding: 0.9rem 1.5rem;
        border-radius: 10px;
        font-weight: 500;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
      }
      
      .newsletter-btn:hover {
        background: var(--accent-light);
      }
      
      /* FOOTER */
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 3rem 2rem;
        max-width: 1200px;
        margin: 0 auto;
      }
      
      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
      }
      
      .footer-brand {
        max-width: 300px;
      }
      
      .footer-brand .logo {
        margin-bottom: 0.75rem;
        display: block;
      }
      
      .footer-brand p {
        color: var(--text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }
      
      .footer-links {
        display: flex;
        gap: 3rem;
      }
      
      .footer-col h4 {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin-bottom: 1rem;
      }
      
      .footer-col a {
        display: block;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        margin-bottom: 0.6rem;
        transition: color 0.2s;
      }
      
      .footer-col a:hover {
        color: var(--accent);
      }
      
      .footer-bottom {
        border-top: 1px solid var(--border-light);
        margin-top: 2rem;
        padding-top: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.85rem;
      }
      
      /* ANIMATIONS */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      
      .animate-in {
        animation: fadeUp 0.8s ease-out forwards;
      }
      
      /* RESPONSIVE */
      @media (max-width: 900px) {
        .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
        .hero-visual { order: -1; }
        .hero-orb { width: 240px; height: 240px; }
        .bento-grid { grid-template-columns: 1fr; }
        .bento-card.featured { grid-column: span 1; }
        .themes-grid { grid-template-columns: repeat(2, 1fr); }
        .quiz-inner { grid-template-columns: 1fr; }
        .quiz-visual { display: none; }
        .footer-inner { flex-direction: column; gap: 2rem; }
        .nav-links { display: none; }
      }
    </style>
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="logo">Aicha Marrhich</a>
        <div class="nav-links">
          <a href="/">Ideas</a>
          <a href="/quiz">Quiz</a>
          <a href="/about">About</a>
          <a href="https://www.linkedin.com/in/aichamarrhich" target="_blank" class="nav-cta">Let's Collaborate</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-label">AI & Education</div>
          <h1>Exploring how <em>AI transforms</em> education, work, and lifelong learning.</h1>
          <p>I synthesize research from OECD, UNESCO, and leading institutions to make complex AI education trends actionable for school leaders, policymakers, and educators.</p>
          <div class="hero-actions">
            <a href="#ideas" class="btn-primary">
              Explore Ideas
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
            <a href="https://www.linkedin.com/in/aichamarrhich" target="_blank" class="btn-secondary">Collaborate</a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="hero-orb">
            <div class="hero-orb-inner"></div>
          </div>
          <div class="hero-emoji">🎓</div>
        </div>
      </div>
    </section>

    <!-- FEATURED IDEAS (BENTO) -->
    <section class="section" id="ideas">
      <div class="section-header">
        <div class="section-label">Ideas Library</div>
        <h2>Featured Ideas</h2>
        <p class="section-desc">Recent essays, research notes, and frameworks on AI in education.</p>
      </div>
      
      <div class="bento-grid">
        {posts.slice(0, 1).map((post: any) => (
          <article class="bento-card featured">
            <a href={post.url} class="bento-link"></a>
            <span class="bento-tag">Latest</span>
            <h3 class="bento-title">{post.frontmatter.title}</h3>
            <p class="bento-desc">{post.frontmatter.description}</p>
            <div class="bento-meta">
              <span>{post.frontmatter.pubDate}</span>
              <span>·</span>
              <span>{post.frontmatter.tags?.[0] || 'Research'}</span>
            </div>
          </article>
        ))}
        
        <article class="bento-card">
          <a href="/quiz" class="bento-link"></a>
          <span class="bento-tag">Interactive</span>
          <h3 class="bento-title">AI Learning Style Quiz</h3>
          <p class="bento-desc">Discover your unique approach to learning in the age of AI. Are you an Explorer, Architect, Guardian, or Collaborator?</p>
          <div class="bento-meta">
            <span>5 min</span>
            <span>·</span>
            <span>Self-Assessment</span>
          </div>
        </article>
        
        {posts.slice(1, 4).map((post: any) => (
          <article class="bento-card">
            <a href={post.url} class="bento-link"></a>
            <span class="bento-tag">{post.frontmatter.tags?.[0] || 'Research'}</span>
            <h3 class="bento-title">{post.frontmatter.title}</h3>
            <p class="bento-desc">{post.frontmatter.description}</p>
            <div class="bento-meta">
              <span>{post.frontmatter.pubDate}</span>
              <span>·</span>
              <span>5 min read</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- RESEARCH THEMES -->
    <section class="section">
      <div class="section-header">
        <div class="section-label">Expertise</div>
        <h2>Research Themes</h2>
        <p class="section-desc">Major areas of focus in AI education and learning transformation.</p>
      </div>
      
      <div class="themes-grid">
        <div class="theme-card">
          <div class="theme-icon">📚</div>
          <div class="theme-name">AI Literacy Frameworks</div>
        </div>
        <div class="theme-card">
          <div class="theme-icon">🎯</div>
          <div class="theme-name">AI Readiness</div>
        </div>
        <div class="theme-card">
          <div class="theme-icon">🗺️</div>
          <div class="theme-name">Curriculum Design</div>
        </div>
        <div class="theme-card">
          <div class="theme-icon">🤖</div>
          <div class="theme-name">Agentic AI</div>
        </div>
        <div class="theme-card">
          <div class="theme-icon">📊</div>
          <div class="theme-name">Learning Analytics</div>
        </div>
        <div class="theme-card">
          <div class="theme-icon">🏛️</div>
          <div class="theme-name">Ed Policy</div>
        </div>
        <div class="theme-card">
          <div class="theme-icon">🧠</div>
          <div class="theme-name">Future Skills</div>
        </div>
        <div class="theme-card">
          <div class="theme-icon">👥</div>
          <div class="theme-name">Human-AI Collaboration</div>
        </div>
      </div>
    </section>

    <!-- QUIZ CTA -->
    <section class="quiz-section">
      <div class="quiz-inner">
        <div class="quiz-content">
          <h2>What's Your AI Learning Style?</h2>
          <p>Take this quick interactive assessment to discover how you approach learning and teaching in the age of AI. Get personalized insights and share your results.</p>
          <a href="/quiz" class="quiz-btn">
            Start the Quiz
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </a>
        </div>
        <div class="quiz-visual">
          <div class="quiz-preview">
            <div class="quiz-preview-item">
              <div class="quiz-preview-letter">A</div>
              <div class="quiz-preview-text">Dive in and experiment</div>
            </div>
            <div class="quiz-preview-item">
              <div class="quiz-preview-letter">B</div>
